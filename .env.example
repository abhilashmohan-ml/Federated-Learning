# ============================================================
# Server settings
# ============================================================
SERVER_SECRET_KEY=CHANGE_ME_strong_random_64_chars
SERVER_DB_URL=postgresql+asyncpg://viral_fl:viral_fl_pass@db:5432/viral_fl
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
FLET_SERVER_PORT=8550

# CORS origins (comma-separated).
# Leave empty to allow all origins without credentials (local dev).
# Production: set to each site's dashboard URL, e.g.:
#   CORS_ORIGINS=https://site1.company.com:8551,https://site2.company.com:8552
CORS_ORIGINS=

# TLS / HTTPS (optional).  Both must be set together.
# Dev:  run scripts/generate_certs.sh then set paths below.
# Prod: use Let's Encrypt or your CA; see docs/PRODUCTION.md.
# SSL_KEYFILE=/certs/server.key
# SSL_CERTFILE=/certs/server.crt

# ============================================================
# Server-side site secrets (set before running scripts/init_db.py)
# These are hashed with bcrypt and stored in site_registry table.
# Each matching client must set SITE_SECRET to the same value.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# ============================================================
SITE_1_SECRET=CHANGE_ME_site1_secret
SITE_2_SECRET=CHANGE_ME_site2_secret
SITE_3_SECRET=CHANGE_ME_site3_secret
SITE_4_SECRET=CHANGE_ME_site4_secret
SITE_5_SECRET=CHANGE_ME_site5_secret

# ============================================================
# Client settings  (one .env per site container)
# ============================================================
SITE_ID=site_1
# Dev (Docker): http://server:8000
# Dev (venv):   http://localhost:8000
# Production:   https://fl-server.company.com  (or public IP)
SERVER_URL=http://server:8000
SITE_SECRET=CHANGE_ME_site1_secret
DP_NOISE_SIGMA=0.01
LOCAL_DATA_PATH=/data/filtration.csv
FLET_CLIENT_PORT=8551

# SSL verification — set false only when using self-signed dev certs
VERIFY_SSL=true
# Connection / request timeouts in seconds
CONNECT_TIMEOUT=10
REQUEST_TIMEOUT=60
# Retries on transient network errors (exponential backoff: 2s, 4s, 8s …)
RETRY_ATTEMPTS=3

# ============================================================
# Shared FL hyperparameters
# ============================================================
LOG_LEVEL=INFO
FL_ROUNDS=50
LOCAL_EPOCHS=5
LEARNING_RATE=0.001
FEDPROX_MU=0.01
MIN_SITES_PER_ROUND=3
ROUND_TIMEOUT_SECONDS=300
